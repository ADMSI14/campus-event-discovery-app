<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="24dp">

    <!-- Title: "Upcoming Events" -->

    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="5dp"
        android:layout_marginEnd="5dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Settings"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/settings_gear" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="40dp"
        android:text="@string/upcoming_events_title"
        android:textSize="40sp"
        android:textColor="@android:color/black"
        android:textStyle="bold" />

    <!-- Selected School Label -->
    <TextView
        android:id="@+id/selectedSchoolLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/titleText"
        android:layout_marginTop="16dp"
        android:background="@drawable/school_label_background"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="University of New Brunswick"
        android:textSize="16sp"
        android:textColor="@android:color/black" />

    <!-- Search Event Subtitle -->
    <TextView
        android:id="@+id/searchEventLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/selectedSchoolLabel"
        android:layout_marginTop="24dp"
        android:text="@string/search_event_label"
        android:textSize="18sp"
        android:textColor="@android:color/black"
        android:textStyle="bold" />

    <!-- Search Event Input Container -->
    <RelativeLayout
        android:id="@+id/searchEventContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/searchEventLabel"
        android:layout_marginTop="8dp"
        android:background="@drawable/search_background"
        android:padding="12dp"
        android:minHeight="48dp">

        <EditText
            android:id="@+id/searchEventEditText"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/searchEventIcon"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:hint="@string/search_event_hint"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#666666"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:autofillHints="eventName"
            android:importantForAutofill="yes"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <ImageView
            android:id="@+id/searchEventIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="@string/search_event_icon_desc"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            app:tint="#000000" />
    </RelativeLayout>

    <!-- Scrollable Events List Container -->
    <FrameLayout
        android:id="@+id/eventsListContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/searchEventContainer"
        android:layout_marginTop="24dp"
        android:layout_above="@id/backButton"
        android:layout_marginBottom="20dp"
        android:background="@drawable/container_background"
        android:padding="8dp">

        <ListView
            android:id="@+id/eventsListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/darker_gray"
            android:dividerHeight="1dp"
            android:scrollbars="vertical"
            android:scrollbarStyle="outsideInset"
            android:fadeScrollbars="false"
            android:scrollbarAlwaysDrawVerticalTrack="true"
            android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
            android:scrollbarTrackVertical="@drawable/scrollbar_track"
            android:scrollbarSize="8dp"
            android:clipToPadding="false"
            android:visibility="visible" />

        <!-- Loading Indicator -->
        <LinearLayout
            android:id="@+id/loadingEventsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/loadingEventsProgressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/loadingEventsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/loading_events"
                android:textSize="16sp"
                android:textColor="@android:color/black" />
        </LinearLayout>
    </FrameLayout>

    <!-- Back Button (Bottom Left) -->
    <ImageView
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="20dp"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="@string/back_button_desc"
        android:visibility="invisible"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/back_button_background"
        android:padding="12dp"
        app:tint="#FFFFFF" />

</RelativeLayout>


